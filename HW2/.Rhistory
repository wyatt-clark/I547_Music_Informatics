library(tuneR)
#start at C octave 3
amp = .5
sr = 8000
bits = 16
y_total = rep(0);
#2 9 5 7 9 5 7 9 12 9
#G C E D C E D C A C
frequency_vector = c(2, 9, 5, 7, 9, 5, 7, 9, 12, 9);
time_vector = c(1, 2, .5, (1/3), (1/6),2, 1, 2, 1, 2);
for (i in 1:10){
f = 440*(2^(-frequency_vector[i]/12))
secs = time_vector[i];
t = seq(0,secs,by=1/sr);
y = amp*sin(2*pi*f*t+runif(1));
y_total = c(y_total, y);
}
#total_time = sum(time_vector)
total_time = length(y_total)*(1/sr)
#make a sine wave at 440 hz, or should it be an octave below?
f = 220*(2^(-9/12));
t = seq(0,total_time, by=1/sr);
t = t[1:length(y_total)]
y = amp*sin(2*pi*f*t + runif(1));
f = 220*(2^(-2/12));
t = seq(0,total_time, by=1/sr);
t = t[1:length(y_total)]
y = y+(amp*sin(2*pi*f*t+runif(1)));
new_y = c(y_total, (y_total+y));
s = floor(2^(bits-2)*new_y)
u = Wave(s, samp.rate = sr, bit=bits)  	# make wave struct.
play(u,"playRWave")
library(tuneR)
#start at C octave 3
amp = .5
sr = 8000
bits = 16
y_total = rep(0);
#2 9 5 7 9 5 7 9 12 9
#G C E D C E D C A C
frequency_vector = c(2, 9, 5, 7, 9, 5, 7, 9, 12, 9);
time_vector = c(1, 2, .5, (1/3), (1/6),2, 1, 2, 1, 2);
for (i in 1:10){
f = 440*(2^(-frequency_vector[i]/12))
secs = time_vector[i];
t = seq(0,secs,by=1/sr);
y = amp*sin(2*pi*f*t+runif(1));
y_total = c(y_total, y);
}
#total_time = sum(time_vector)
total_time = length(y_total)*(1/sr)
#make a sine wave at 440 hz, or should it be an octave below?
f = 220*(2^(-9/12));
t = seq(0,total_time, by=1/sr);
t = t[1:length(y_total)]
y = amp*sin(2*pi*f*t + runif(1));
f = 220*(2^(-2/12));
t = seq(0,total_time, by=1/sr);
t = t[1:length(y_total)]
y = y+(amp*sin(2*pi*f*t+runif(1)));
new_y = c(y_total, (y_total+y));
s = floor(2^(bits-2)*new_y)
u = Wave(s, samp.rate = sr, bit=bits)  	# make wave struct.
play(u,"./playRWave")
